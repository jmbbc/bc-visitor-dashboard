rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow reads for core collections used by the dashboard
    match /units/{unitId} {
      allow get, list: if true;

      // Allow admins (custom claim `admin`) to create/update/delete units
      allow create, update, delete: if request.auth != null
        && request.auth.token.admin == true
        && isValidUnit(request.resource.data);
    }

    // Metadata about unit imports (e.g., last CSV upload time)
    match /unitMeta/{docId} {
      // Allow public reads so visitor form can show last update time
      allow read: if true;
      // Writes restricted to admins
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Parking data: require authenticated reads; restrict writes to admins
    match /parkingSlots/{slotId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }
    match /parkingMeta/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Water readings: allow authenticated reads; restrict writes to admins only
    match /waterReadings/{docId} {
      // only signed-in users can view the daily readings
      allow read: if request.auth != null;
      // only admin users (custom claim `admin`) may create/update/delete readings
      allow create, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Daily outstanding snapshots used for monthly arrears chart
    match /outstandingSnapshots/{snapshotId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && isValidOutstandingSnapshot(request.resource.data, snapshotId);
      allow delete: if isAdmin();
    }

    // Visitor form responses: allow public create with strict validation
    match /responses/{respId} {
      allow create: if isValidResponse(request.resource.data);
      allow update: if (isAdmin() && isValidResponse(request.resource.data))
        || canAmendResponse(resource.data, request.resource.data, respId);
      allow read, delete: if request.auth != null;
    }

    // Dedupe keys for transaction-based duplicate prevention (public create/update only with linked response in same request)
    match /dedupeKeys/{keyId} {
      allow get: if true;
      allow create, update: if isValidDedupeKey(request.resource.data)
        && existsAfter(/databases/$(database)/documents/responses/$(request.resource.data.responseId));
      allow delete, list: if false;
    }

    // Overnight lock to force Pelawat Bermalam vehicle combination in one submission
    match /overnightLocks/{lockId} {
      allow get: if true;
      allow create, update: if isValidOvernightLock(request.resource.data, lockId)
        && existsAfter(/databases/$(database)/documents/responses/$(request.resource.data.responseId));
      allow delete, list: if false;
    }

    // Audit logs: authenticated users may write and read; deletes disabled
    match /audit/{docId} {
      allow create, read: if request.auth != null;
      allow delete: if false;
      allow update: if false;
    }

    // Deny everything else by default (explicit)
    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }

    // Validation helper for a unit doc
    function isValidUnit(data) {
      return data is map
        && (data.keys().hasAll(['arrears', 'arrearsAmount', 'category', 'lastUpdatedAt', 'lastUpdatedBy'])
            || data.keys().hasAny(['arrears','arrearsAmount','category','originalUnit']))
        && (data.arrears is bool)
        && (data.arrearsAmount is number || data.arrearsAmount == null)
        && (data.category is string || !('category' in data))
        && (data.lastUpdatedAt is timestamp || !('lastUpdatedAt' in data))
        && (data.lastUpdatedBy is string || !('lastUpdatedBy' in data));
    }

    // Validation helper for a visitor response doc
    function isValidResponse(data) {
      return data is map
        // required keys
        && data.keys().hasAll(['hostUnit','hostName','category','visitorName','eta','createdAt','updatedAt','status'])
        // allowed optional keys
        && data.keys().hasOnly([
          'hostUnit','hostUnitFound','hostName','hostPhone','category','subCategory','entryDetails','companyName',
          'visitorName','visitorPhone','stayOver','eta','etd','vehicleNo','vehicleNumbers','vehicleType',
          'vehicleRowsDetailed',
          'subCategoryHelp','status','createdAt','updatedAt',
          'amendToken',
          // unit snapshot fields
          'unitCategory','unitArrears','unitArrearsAmount','unitLastUpdatedAt'
        ])
        // type checks
        && (data.hostUnit is string)
        && (data.hostUnitFound is bool || !('hostUnitFound' in data))
        && (data.hostName is string)
        && (data.hostPhone is string || !('hostPhone' in data))
        && (data.category is string)
        && (data.subCategory is string || !('subCategory' in data))
        && (data.entryDetails is string || !('entryDetails' in data))
        && (data.companyName is string || !('companyName' in data))
        && (data.visitorName is string)
        && (data.visitorPhone is string || !('visitorPhone' in data))
        && (data.stayOver is string || !('stayOver' in data))
        && (data.eta is timestamp)
        && (data.etd is timestamp || data.etd == null || !('etd' in data))
        && (data.vehicleNo is string || !('vehicleNo' in data))
        && (data.vehicleNumbers is list || !('vehicleNumbers' in data))
        && (data.vehicleRowsDetailed is list || !('vehicleRowsDetailed' in data))
        && (data.vehicleType is string || !('vehicleType' in data))
        && (data.subCategoryHelp is string || !('subCategoryHelp' in data))
        && (data.status is string)
        && (data.createdAt is timestamp)
        && (data.updatedAt is timestamp)
        && (data.amendToken is string || !('amendToken' in data))
        // unit snapshot optional types
        && (data.unitCategory is string || !('unitCategory' in data))
        && (data.unitArrears is bool || !('unitArrears' in data))
        && (data.unitArrearsAmount is number || !('unitArrearsAmount' in data))
        && (data.unitLastUpdatedAt is timestamp || !('unitLastUpdatedAt' in data));
    }

    function isValidDedupeKey(data) {
      return data is map
        && data.keys().hasOnly(['responseId','hostUnit','visitorPhone','visitorName','etaDate','createdAt','amendToken'])
        && (data.responseId is string)
        && (data.hostUnit is string)
        && (data.visitorPhone is string)
        && (data.visitorName is string)
        && (data.etaDate is string)
        && (data.createdAt is timestamp)
        && (data.amendToken is string || !('amendToken' in data));
    }

    function isValidOutstandingSnapshot(data, snapshotId) {
      return data is map
        && data.keys().hasOnly(['dateKey','monthKey','day','totalOutstanding','unitsWithArrears','totalUnits','source','capturedBy','capturedAt','updatedAt'])
        && (data.dateKey is string)
        && (snapshotId == data.dateKey)
        && (data.monthKey is string)
        && (data.day is int)
        && (data.day >= 1 && data.day <= 31)
        && (data.totalOutstanding is number)
        && (data.totalOutstanding >= 0)
        && (data.unitsWithArrears is int)
        && (data.unitsWithArrears >= 0)
        && (data.totalUnits is int)
        && (data.totalUnits >= 0)
        && (data.source is string)
        && (data.capturedBy is string)
        && (data.capturedAt is timestamp || !('capturedAt' in data))
        && (data.updatedAt is timestamp || !('updatedAt' in data));
    }

    function isValidOvernightLock(data, lockId) {
      return data is map
        && data.keys().hasOnly(['unit','startDate','endDate','category','stayOver','responseId','updatedAt','amendToken'])
        && (data.unit is string)
        && (data.startDate is timestamp)
        && (data.endDate is timestamp)
        && (data.category is string)
        && (data.stayOver is string)
        && (data.responseId is string)
        && (data.updatedAt is timestamp)
        && (data.amendToken is string || !('amendToken' in data))
        && (data.category == 'Pelawat')
        && (data.stayOver in ['Yes', 'No'])
        && (lockId == ('unit-' + data.unit))
        && (data.startDate <= data.endDate);
    }

    function canAmendResponse(oldData, newData, respId) {
      let lockId = 'unit-' + oldData.hostUnit;
      return isValidResponse(newData)
        && oldData.category == 'Pelawat'
        && oldData.status == 'Pending'
        && newData.status == oldData.status
        && oldData.hostUnit == newData.hostUnit
        && oldData.category == newData.category
        && oldData.eta == newData.eta
        && oldData.createdAt == newData.createdAt
        && oldData.amendToken is string
        && newData.amendToken == oldData.amendToken
        && request.time < oldData.createdAt + duration.value(24, 'h')
        && exists(/databases/$(database)/documents/overnightLocks/$(lockId))
        && get(/databases/$(database)/documents/overnightLocks/$(lockId)).data.responseId == respId
        && get(/databases/$(database)/documents/overnightLocks/$(lockId)).data.amendToken == oldData.amendToken;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
  }
}
